\renewcommand{\sectionmark}[1]{%
    \markright{\thesection.\ \MakeUppercase{#1}}%
}
\renewcommand{\subsectionmark}[1]{}
\renewcommand{\subsubsectionmark}[1]{}
\makeatother
\newcommand{\hmrightinfo}[2]{%
    {\footnotesize
        \ifstrempty{#1}{}{%
            \textbf{#1}%
        }%
        \ifstrempty{#2}{}{%
            \ifstrempty{#1}{}{ | }%
            \textit{#2}%
        }%
    }%
}
\newcommand{\hmsection}[3]{%
    \refstepcounter{section}%
    \sectionmark{#1}%
    \addcontentsline{toc}{section}{\protect\numberline{\thesection}#1}%
    \par\addvspace{3.5ex plus 1ex minus .2ex}%
    \noindent
    \begin{minipage}[t]{.8\textwidth}
        \raggedright\Large\bfseries \thesection\quad #1
    \end{minipage}%
    \hfill\hmrightinfo{#2}{#3}\par
    \nobreak\addvspace{2.3ex plus .2ex}%
}
\newcommand{\hmsubsection}[3]{%
    \refstepcounter{subsection}%
    \addcontentsline{toc}{subsection}{\protect\numberline{\thesubsection}#1}%
    \par\addvspace{3.25ex plus 1ex minus .2ex}%
    \noindent
    \begin{minipage}[t]{.8\textwidth}
        \raggedright\large\bfseries \thesubsection\quad #1
    \end{minipage}%
    \hfill\hmrightinfo{#2}{#3}\par
    \nobreak\addvspace{1.5ex plus .2ex}%
}
\newcommand{\hmsubsubsection}[3]{%
    \refstepcounter{subsubsection}%
    \addcontentsline{toc}{subsubsection}{\protect\numberline{\thesubsubsection}#1}%
    \par\addvspace{3.25ex plus 1ex minus .2ex}%
    \noindent
    \begin{minipage}[t]{.8\textwidth}
        \raggedright\normalsize\bfseries \thesubsubsection\quad #1
    \end{minipage}%
    \hfill\hmrightinfo{#2}{#3}\par
    \nobreak\addvspace{1.5ex plus .2ex}%
}
\setcounter{secnumdepth}{3}

