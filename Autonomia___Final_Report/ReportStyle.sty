\definecolor{accent}{RGB}{20, 160, 90}
\definecolor{darktext}{RGB}{15, 18, 22}
\definecolor{softgray}{RGB}{110, 115, 120}
\definecolor{midgray}{RGB}{160, 165, 170}

% TOC depth — sections and subsections only
\setcounter{tocdepth}{2}

% Relaxed TOC vertical spacing (two-page layout)
\setlength{\cftbeforesecskip}{6pt}
\setlength{\cftbeforesubsecskip}{2pt}

% Section styling — bold dark sans
\renewcommand{\cftsecfont}{\sffamily\bfseries\color{darktext}\small}
\renewcommand{\cftsecpagefont}{\sffamily\color{softgray}\small}
\renewcommand{\cftsecleader}{\sffamily\color{midgray}\cftdotfill{\cftdotsep}}

% Subsection styling — indented, regular weight
\renewcommand{\cftsubsecfont}{\sffamily\color{darktext}\small}
\renewcommand{\cftsubsecpagefont}{\sffamily\color{softgray}\small}
\renewcommand{\cftsubsecleader}{\sffamily\color{midgray}\cftdotfill{\cftdotsep}}

% Compact dot spacing
\renewcommand{\cftdotsep}{2}

% Indentation
\setlength{\cftsecindent}{0pt}
\setlength{\cftsubsecindent}{1em}

% Number column widths
\setlength{\cftsecnumwidth}{2em}
\setlength{\cftsubsecnumwidth}{2.6em}

